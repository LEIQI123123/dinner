.banner {
  height: 220rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.banner-item {
  height: 220rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}
.b-emoji {
  font-size: 110rpx;
  margin-right: 24rpx;
}
.b-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}
.b-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  margin-top: 8rpx;
}

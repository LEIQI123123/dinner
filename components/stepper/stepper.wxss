.stepper {
  display: inline-flex;
  align-items: center;
}
.btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
  transition: all .15s ease;
}
.minus {
  border: 2rpx solid #A89684;
  color: #A89684;
  background: #fff;
}
.plus {
  background: linear-gradient(135deg, #FFB088, #FF7E5F);
  color: #fff;
}
.btn.disabled { opacity: .35; }
.btn:active { transform: scale(0.9); }
.num {
  min-width: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3B32;
}

.spec-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.spec-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: 0;
  animation: slideUp .25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.spec-head {
  display: flex;
  align-items: center;
  position: relative;
}
.spec-head .thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(255, 126, 95, 0.18);
}
.spec-head .thumb .emoji {
  font-size: 64rpx;
}
.head-info {
  margin-left: 20rpx;
  flex: 1;
}
.head-info .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3B32;
}
.head-info .price {
  font-size: 36rpx;
  color: #FF5A3C;
  font-weight: 700;
  margin-top: 8rpx;
}
.close {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 40rpx;
  color: #A89684;
  padding: 8rpx;
}
.spec-block {
  margin-top: 28rpx;
}
.spec-title {
  font-size: 26rpx;
  color: #A89684;
  margin-bottom: 14rpx;
}
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  background: #FFF8F0;
  color: #4A3B32;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  transition: all .15s ease;
}
.chip.on {
  background: rgba(255, 126, 95, 0.12);
  color: #FF7E5F;
  border-color: #FF7E5F;
  font-weight: 600;
}
.spec-foot {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(168, 150, 132, 0.15);
}
.confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
}

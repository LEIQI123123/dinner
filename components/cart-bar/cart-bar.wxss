.cart-bar {
  position: fixed;
  left: 0; right: 0;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  margin: 0 24rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 95, 0.2);
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 24rpx;
  z-index: 90;
}
.cart-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB088, #FF7E5F);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 126, 95, 0.4);
  transition: transform .15s ease;
}
.cart-icon:active { transform: scale(0.92); }
.cart-icon .emoji {
  font-size: 40rpx;
}
.cart-icon .badge {
  position: absolute;
  top: -6rpx; right: -6rpx;
  min-width: 30rpx; height: 30rpx;
  padding: 0 6rpx;
  border-radius: 15rpx;
  background: #FF6B6B;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}
.cart-total {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}
.cart-total .price {
  font-size: 36rpx;
  color: #FF5A3C;
  font-weight: 700;
}
.cart-total .tip {
  font-size: 20rpx;
}
.checkout {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 42rpx;
  font-size: 28rpx;
}

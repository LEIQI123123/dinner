.dish-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(255, 126, 95, 0.18);
}
.thumb .emoji {
  font-size: 76rpx;
}
.thumb.img {
  padding: 0;
  display: block;
}
.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3B32;
}
.tags {
  margin-top: 8rpx;
}
.tags .tag {
  margin-right: 8rpx;
}
.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
}
.meta .rating {
  color: #FF9A3C;
  margin-left: 12rpx;
}
.bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
}
.bottom .price {
  font-size: 34rpx;
}
.bottom .oprice {
  font-size: 22rpx;
  color: #A89684;
  text-decoration: line-through;
  margin-left: 10rpx;
}

/* grid 模式（首页推荐） */
.mode-grid {
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 0;
}
.mode-grid .thumb {
  width: 100%;
  height: 180rpx;
  border-radius: 20rpx 20rpx 0 0;
}
.mode-grid .info {
  margin-left: 0;
  padding: 16rpx;
}
.mode-grid .name {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">
      <text class="emoji">{{item.icon}}</text>
      <view wx:if="{{item.badge > 0}}" class="badge">{{item.badge > 99 ? '99+' : item.badge}}</view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>

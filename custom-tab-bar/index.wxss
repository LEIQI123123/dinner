.tab-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  box-shadow: 0 -8rpx 24rpx rgba(255, 126, 95, 0.16);
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #A89684;
  transition: all .2s ease;
}
.tab-item.active { color: #FF7E5F; }
.tab-icon {
  position: relative;
  font-size: 44rpx;
  line-height: 1;
}
.tab-item.active .emoji {
  transform: scale(1.18);
  display: inline-block;
}
.tab-text {
  font-size: 22rpx;
  margin-top: 6rpx;
}
.badge {
  position: absolute;
  top: -12rpx; right: -24rpx;
  min-width: 30rpx; height: 30rpx;
  padding: 0 6rpx;
  border-radius: 15rpx;
  background: #FF6B6B;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 107, 0.4);
}

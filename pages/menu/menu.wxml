<view class="menu">
  <view class="menu-head">
    <text class="mh-title">🍽️ 菜单</text>
    <view class="mh-manage" bindtap="goManage">⚙️ 管理</view>
  </view>

  <view class="menu-body">
    <scroll-view scroll-y class="cat-tabs" show-scrollbar="{{false}}">
      <view
        wx:for="{{catList}}"
        wx:key="id"
        class="cat-tab {{activeCat === item.id ? 'on' : ''}}"
        data-id="{{item.id}}"
        bindtap="onTapCat"
      >
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view
      scroll-y
      class="dish-list"
      scroll-into-view="{{scrollInto}}"
      bindscroll="onScroll"
      scroll-with-animation
    >
      <block wx:for="{{catList}}" wx:key="id">
        <view class="cat-header" id="cat-{{item.id}}">{{item.icon}} {{item.name}}</view>
        <dish-card
          wx:for="{{item.dishes}}"
          wx:for-item="d"
          wx:key="id"
          dish="{{d}}"
          mode="list"
          bind:select="goDetail"
        />
      </block>
      <view class="list-bottom"></view>
    </scroll-view>
  </view>
</view>

<cart-bar visible="{{cartVisible}}" count="{{cartCount}}" total="{{cartTotal}}" />

<view class="page-pad addr">
  <block wx:if="{{addresses.length}}">
    <view class="card addr-item" wx:for="{{addresses}}" wx:key="id" data-id="{{item.id}}" bindtap="selectAddr">
      <view class="addr-top row-between">
        <view class="who">
          <text class="name">{{item.name}}</text>
          <text class="phone">{{item.phone}}</text>
          <text wx:if="{{item.isDefault}}" class="tag">默认</text>
          <text class="tag tag-plain">{{item.tag}}</text>
        </view>
        <view class="ops">
          <text class="op" catchtap="editAddr" data-id="{{item.id}}">✏️</text>
          <text class="op" catchtap="removeAddr" data-id="{{item.id}}">🗑️</text>
        </view>
      </view>
      <view class="addr-text">{{item.address}}</view>
      <view wx:if="{{!item.isDefault}}" class="set-default" catchtap="setDefault" data-id="{{item.id}}">设为默认</view>
    </view>
  </block>
  <empty wx:else emoji="📍" text="还没有收货地址，添加一个吧~" />
</view>

<view class="addr-foot">
  <view class="add-btn" bindtap="addAddr">＋ 新增地址</view>
  <view wx:if="{{fromCheckout}}" class="use-btn" bindtap="confirmSelect">使用选中地址</view>
</view>

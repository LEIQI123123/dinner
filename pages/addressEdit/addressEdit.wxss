.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}
.form-row.col {
  flex-direction: column;
  align-items: stretch;
}
.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #4A3B32;
  font-weight: 600;
  flex-shrink: 0;
}
.input {
  flex: 1;
  font-size: 28rpx;
}
.tags-pick {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.tchip {
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  background: #FFF3E9;
  color: #A89684;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  transition: all .15s ease;
}
.tchip.on {
  background: rgba(255, 126, 95, 0.12);
  color: #FF7E5F;
  border-color: #FF7E5F;
  font-weight: 600;
}
.textarea {
  width: 100%;
  height: 140rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #FFF8F0;
  border-radius: 16rpx;
  box-sizing: border-box;
}
.save-btn {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  padding-bottom: calc(env(safe-area-inset-bottom));
}

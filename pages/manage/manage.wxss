.manage {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #FFF8F0;
}
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.top-bar .hint {
  font-size: 22rpx;
  color: #A89684;
}
.add-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.group {
  margin-bottom: 32rpx;
}
.group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A3B32;
  margin-bottom: 16rpx;
}
.row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 126, 95, 0.08);
}
.r-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(255, 126, 95, 0.18);
}
.r-thumb .r-emoji {
  font-size: 52rpx;
}
.r-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.r-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3B32;
}
.r-meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}
.r-price {
  font-size: 26rpx;
  color: #FF5A3C;
  font-weight: 700;
}
.r-tag {
  font-size: 20rpx;
  color: #fff;
  background: #FF9A3C;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  margin-left: 12rpx;
}
.r-tag.dim {
  background: #FFE3D2;
  color: #FF7E5F;
}
.r-ops {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.op {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}
.op.edit {
  color: #FF7E5F;
  background: #FFF3E9;
  margin-bottom: 12rpx;
}
.op.del {
  color: #FF5A3C;
  background: #FFE9E5;
}
.empty-tip {
  text-align: center;
  color: #A89684;
  font-size: 26rpx;
  margin-top: 120rpx;
}

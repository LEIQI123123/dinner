<view class="success" wx:if="{{order}}">
  <view class="ok-emoji">🎉</view>
  <view class="ok-title">下单成功！</view>
  <view class="ok-sub">商家已收到订单，马上为您准备~</view>

  <view class="card info">
    <view class="row-between"><text class="muted">订单号</text><text class="mono">{{order.orderNo}}</text></view>
    <view class="divider"></view>
    <view class="row-between"><text class="muted">配送至</text><text class="addr">{{order.address.name}} {{order.address.phone}}</text></view>
    <view class="addr-detail">{{order.address.address}}</view>
    <view class="divider"></view>
    <view class="row-between"><text class="muted">实付金额</text><text class="price big">¥{{order.total}}</text></view>
    <view class="row-between"><text class="muted">预计送达</text><text>约 {{order.estimatedMinutes}} 分钟</text></view>
  </view>

  <view class="home-btn safe-bottom btn-primary" bindtap="goHome">返回首页</view>
</view>

<view wx:else class="success">
  <view class="ok-emoji">🧾</view>
  <view class="ok-title">暂无订单</view>
  <view class="home-btn safe-bottom btn-primary" bindtap="goHome">返回首页</view>
</view>

.success {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}
.ok-emoji {
  font-size: 140rpx;
}
.ok-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A3B32;
  margin-top: 20rpx;
}
.ok-sub {
  font-size: 26rpx;
  color: #A89684;
  margin-top: 12rpx;
}
.info {
  width: 100%;
  margin-top: 50rpx;
  font-size: 28rpx;
}
.info .row-between {
  margin-bottom: 16rpx;
}
.info .mono {
  font-family: "SF Mono", "Consolas", monospace;
  font-size: 24rpx;
}
.info .addr {
  font-weight: 600;
}
.addr-detail {
  font-size: 24rpx;
  color: #6b5b50;
  margin-top: 6rpx;
}
.price.big {
  font-size: 44rpx;
  color: #FF5A3C;
  font-weight: 700;
}
.home-btn {
  position: fixed;
  left: 24rpx; right: 24rpx; bottom: 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  margin-bottom: calc(env(safe-area-inset-bottom));
}

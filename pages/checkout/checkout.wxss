.addr-card {
  margin-bottom: 20rpx;
}
.addr-top {
  margin-bottom: 10rpx;
}
.who .name {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 14rpx;
}
.who .phone {
  font-size: 26rpx;
  color: #6b5b50;
  margin-right: 12rpx;
}
.arrow {
  font-size: 40rpx;
  color: #A89684;
}
.addr-text {
  font-size: 26rpx;
  color: #6b5b50;
}
.no-addr {
  font-size: 28rpx;
  color: #FF7E5F;
}
.goods {
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}
.g-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.g-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 126, 95, 0.18);
}
.g-thumb .g-emoji {
  font-size: 48rpx;
}
.g-thumb.img {
  padding: 0;
}
.g-info {
  flex: 1;
  min-width: 0;
}
.g-info .name {
  font-size: 28rpx;
  font-weight: 600;
}
.g-info .spec {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.g-right {
  text-align: right;
}
.g-right .price {
  font-size: 28rpx;
  display: block;
}
.g-right .qx {
  font-size: 22rpx;
  color: #A89684;
}
.remark-card {
  margin-bottom: 20rpx;
}
.remark {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
  padding: 16rpx;
  background: #FFF8F0;
  border-radius: 16rpx;
  box-sizing: border-box;
}
.summary {
  font-size: 28rpx;
}
.summary .row-between {
  margin-bottom: 14rpx;
}
.total-row {
  font-size: 30rpx;
  font-weight: 600;
}
.price.big {
  font-size: 44rpx;
  color: #FF5A3C;
  font-weight: 700;
}
.co-foot {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(255, 126, 95, 0.12);
  z-index: 90;
}
.submit-btn {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 48rpx;
  font-size: 30rpx;
}
